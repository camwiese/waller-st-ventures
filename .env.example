# Supabase (create project at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_DATA_ROOM_BASE_PATH=/pst

# GP email - only this user can access /admin
GP_EMAIL=your-email@example.com

# Resend (resend.com) - for investor notification emails
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: comma-separated emails to exclude from view notifications (e.g. your test accounts)
# NOTIFICATION_EXCLUDE_EMAILS=cam@worldsfair.co

# Optional: minutes of inactivity before "is back" notification (default 60)
# NOTIFICATION_SESSION_GAP_MINUTES=60

# Optional: base URL for links in emails (defaults to waller-street-ventures.vercel.app)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Auth sender email for filtering Resend emails in admin
AUTH_SENDER_EMAIL=hello@wallerstreetventures.com

# Mux (mux.com) - for video streaming
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_SIGNING_KEY_ID=your-mux-signing-key-id
MUX_SIGNING_KEY_PRIVATE=your-mux-signing-key-private-base64
MUX_PLAYBACK_ID=your-mux-playback-id

# Vercel Mux integration may inject prefixed names like these instead.
# The app will accept either the unprefixed values above or these aliases.
# pst_interview_MUX_TOKEN_ID=your-mux-token-id
# pst_interview_MUX_TOKEN_SECRET=your-mux-token-secret
# pst_interview_MUX_SIGNING_KEY_ID=your-mux-signing-key-id
# pst_interview_MUX_SIGNING_KEY_PRIVATE=your-mux-signing-key-private-base64
# pst_interview_MUX_PLAYBACK_ID=your-mux-playback-id

# Local-only: bypass admin auth checks while developing on localhost
# NEVER enable this in production.
# LOCAL_DEV_ADMIN_BYPASS=true
